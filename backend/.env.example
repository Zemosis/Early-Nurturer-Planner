# ── Database (Cloud SQL PostgreSQL) ──────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Use the Cloud SQL instance public IP for local dev.
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@34.69.136.252:5432/nurture_db

# ── Google Cloud Platform ────────────────────────────────────
GCP_PROJECT_ID=early-nurturer-planner
GCS_BUCKET_NAME=early-nurturer-planner-assets

# Path to the service account JSON key file.
# Run scripts/gcp-phase1-setup.sh to generate it, or ask a teammate.
# On Cloud Run this is not needed (uses built-in SA identity).
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/nurture-backend-sa-key-v2.json

# ── Vertex AI ────────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1

# ── YouTube Data API ─────────────────────────────────────────
YOUTUBE_API_KEY=YOUR_YOUTUBE_API_KEY
