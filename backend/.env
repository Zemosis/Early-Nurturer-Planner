# ── Database (Cloud SQL PostgreSQL) ──────────────────────────
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# Use the Cloud SQL instance public IP from your provisioning output.
DATABASE_URL=postgresql+asyncpg://postgres:earlynurturer123!@34.69.136.252:5432/nurture_db

# ── Google Cloud Platform ────────────────────────────────────
GCP_PROJECT_ID=early-nurturer-planner
GCS_BUCKET_NAME=early-nurturer-planner-assets

# Path to the service account JSON key file (absolute or relative to project root).
# Downloaded by scripts/gcp-phase1-setup.sh → nurture-backend-sa-key.json
GOOGLE_APPLICATION_CREDENTIALS=/home/turuu/workspace/Early-Nurturer-Planner/nurture-backend-sa-key.json

# ── Vertex AI ────────────────────────────────────────────────
VERTEX_AI_LOCATION=us-central1
